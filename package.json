{
  "name": "dosound-tracker",
  "private": true,
  "version": "1.0.21",
  "type": "module",
  "description": "DOSOUND Tracker",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/bump-version.mjs && npm run build:core",
    "build:core": "tsc -b && vite build",
    "lint": "eslint .",
    "test": "vitest run",
    "preview": "vite preview",
    "electron:dev": "concurrently -k \"npm run dev\" \"wait-on http://localhost:8008 && electron .\"",
    "electron:build": "npm run build:core && electron-builder"
  },
  "dependencies": {
    "js-yaml": "^4.1.0",
    "lucide-react": "^0.460.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.10.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.0",
    "concurrently": "^9.1.0",
    "electron": "^28.2.0",
    "electron-builder": "^24.13.3",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^27.2.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.3",
    "vite": "npm:rolldown-vite@7.2.2",
    "vitest": "^3.2.0",
    "wait-on": "^7.2.0"
  },
  "overrides": {
    "vite": "npm:rolldown-vite@7.2.2"
  },
  "author": "Zoltar X / New Generation",
  "build": {
    "appId": "com.dosound.tracker",
    "productName": "DOSOUND Tracker",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "mac": {
      "category": "public.app-category.music",
      "icon": "public/icons/icon-512.png"
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ],
      "icon": "public/icons/icon-512.png"
    },
    "linux": {
      "target": [
        "AppImage",
        "tar.gz"
      ],
      "category": "AudioVideo",
      "icon": "public/icons/icon-512.png"
    }
  }
}
