{
  "name": "dosound-tracker",
  "private": true,
  "version": "1.2.4",
  "type": "module",
  "description": "DOSOUND Tracker",
  "main": "electron/main.cjs",
  "homepage": "https://github.com/zoltraks/dosound-tracker",
  "repository": {
    "type": "git",
    "url": "https://github.com/zoltraks/dosound-tracker.git"
  },
  "keywords": [
    "chiptune",
    "tracker",
    "ym2149",
    "atari-st",
    "dosound",
    "music",
    "synthesizer",
    "assembly"
  ],
  "scripts": {
    "dev": "vite",
    "build": "node scripts/bump-version.mjs && npm run build:core",
    "build:core": "tsc -b && vite build",
    "lint": "eslint .",
    "test": "vitest run",
    "preview": "vite preview",
    "electron:dev": "concurrently -k \"npm run dev\" \"wait-on http://localhost:8008 && electron .\"",
    "electron:build": "npm run build:core && electron-builder"
  },
  "dependencies": {
    "js-yaml": "^4.1.0",
    "lucide-react": "^0.460.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@babel/core": "^7.28.5",
    "@eslint/js": "^9.39.1",
    "@testing-library/react": "^16.3.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.10.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.0",
    "concurrently": "^9.1.0",
    "electron": "^39.2.6",
    "electron-builder": "^24.13.3",
    "eslint": "^9.39.1",
    "eslint-formatter-compact": "^9.0.1",
    "eslint-formatter-unix": "^9.0.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^27.2.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.3",
    "vite": "npm:rolldown-vite@7.2.2",
    "vitest": "^3.2.0",
    "wait-on": "^7.2.0"
  },
  "overrides": {
    "vite": "npm:rolldown-vite@7.2.2"
  },
  "author": {
    "name": "Filip Golewski",
    "email": "f.golewski@gmail.com",
    "url": "http://home.alyx.pl/"
  },
  "company": "New Generation",
  "license": "MIT",
  "build": {
    "appId": "com.dosound.tracker",
    "productName": "DOSOUND Tracker",
    "copyright": "Copyright © 2024 Filip Golewski",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "artifactName": "${name}-${version}-${os}-${arch}.${ext}",
    "mac": {
      "category": "public.app-category.music",
      "icon": "public/icons/icon-512.png"
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ],
      "icon": "public/icons/icon.ico",
      "publisherName": "Filip Golewski",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "DOSOUND Tracker",
      "uninstallDisplayName": "DOSOUND Tracker",
      "installerIcon": "public/icons/icon.ico",
      "uninstallerIcon": "public/icons/icon.ico",
      "license": "LICENSE",
      "warningsAsErrors": false
    },
    "linux": {
      "target": [
        "AppImage",
        "tar.gz"
      ],
      "category": "AudioVideo",
      "icon": "public/icons/icon-512.png"
    }
  }
}
